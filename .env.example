# --- LiveKit (server SDK + Python agent worker) ---
# Create a project at https://cloud.livekit.io or self-host.
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Exposed to the browser so the React app can connect.
VITE_LIVEKIT_URL="wss://your-project.livekit.cloud"

# --- Models and audio (used by the Python agent in agent/) ---
# Gemini 3.5 Flash via langchain-google-genai. Library checks GOOGLE_API_KEY
# first, then falls back to GEMINI_API_KEY.
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Deepgram Nova-3 streaming STT.
DEEPGRAM_API_KEY=""

# Fish Audio TTS. Get a key at https://fish.audio. Browse
# https://fish.audio/text-to-speech/?lang=en and copy the reference ID
# of your chosen voice into FISHAUDIO_VOICE_ID.
FISHAUDIO_API_KEY=""
FISHAUDIO_VOICE_ID=""

# --- App ---
APP_URL="http://localhost:3000"
